{
    "openapi": "3.0.3",
    "info": {
        "title": "Olivia Pizza API",
        "version": "1.0.0",
        "description": "API для пиццерии Olivia - меню, заказы, интеграция с r-keeper",
        "contact": {
            "name": "API Support",
            "email": "support@olivia-pizza.ru"
        }
    },
    "paths": {
        "/api/cart/": {
            "get": {
                "operationId": "cart_list",
                "description": "Возвращает текущую корзину пользователя или гостя со всеми товарами и итоговой суммой.",
                "summary": "Получить корзину",
                "tags": [
                    "Корзина"
                ],
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {
                        "basicAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Cart"
                                    }
                                }
                            }
                        },
                        "description": "Корзина успешно получена"
                    }
                }
            }
        },
        "/api/cart/clear/": {
            "delete": {
                "operationId": "cart_clear_destroy",
                "description": "Полностью удаляет все товары из корзины.",
                "summary": "Очистить корзину",
                "tags": [
                    "Корзина"
                ],
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {
                        "basicAuth": []
                    },
                    {}
                ],
                "responses": {
                    "204": {
                        "description": "Корзина успешно очищена"
                    }
                }
            }
        },
        "/api/cart/items/": {
            "post": {
                "operationId": "cart_items_create",
                "description": "Добавляет товар в корзину. По умолчанию добавляется 1 штука, но можно указать нужное количество в поле `quantity`. Если товар уже есть в корзине, его количество увеличивается.",
                "summary": "Добавить товар в корзину",
                "tags": [
                    "Товары в корзине"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "product": {
                                        "type": "integer",
                                        "description": "ID продукта",
                                        "example": 5
                                    },
                                    "quantity": {
                                        "type": "integer",
                                        "description": "Количество (по умолчанию 1)",
                                        "example": 1,
                                        "default": 1,
                                        "minimum": 1
                                    }
                                },
                                "required": [
                                    "product"
                                ]
                            }
                        }
                    }
                },
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {
                        "basicAuth": []
                    },
                    {}
                ],
                "responses": {
                    "201": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CartItem"
                                }
                            }
                        },
                        "description": "Товар успешно добавлен"
                    },
                    "400": {
                        "description": "Ошибка валидации"
                    }
                }
            }
        },
        "/api/cart/items/{id}/": {
            "delete": {
                "operationId": "cart_items_destroy",
                "description": "Удаляет одну единицу товара из корзины. Если передать параметр `?all=true`, удалятся все единицы этого товара.",
                "summary": "Удалить товар из корзины",
                "parameters": [
                    {
                        "in": "query",
                        "name": "all",
                        "schema": {
                            "type": "boolean",
                            "default": false
                        },
                        "description": "Если true, удаляет все единицы товара (по умолчанию false)"
                    },
                    {
                        "in": "path",
                        "name": "id",
                        "schema": {
                            "type": "integer"
                        },
                        "description": "A unique integer value identifying this cart item.",
                        "required": true
                    }
                ],
                "tags": [
                    "Товары в корзине"
                ],
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {
                        "basicAuth": []
                    },
                    {}
                ],
                "responses": {
                    "204": {
                        "description": "Товар успешно удален"
                    },
                    "403": {
                        "description": "Нельзя удалять товары из чужой корзины"
                    },
                    "404": {
                        "description": "Товар не найден в корзине"
                    }
                }
            }
        },
        "/api/cms/blocks/": {
            "get": {
                "operationId": "cms_blocks_list",
                "description": "GET /api/cms/blocks/\nВозвращает все активные блоки главной страницы",
                "tags": [
                    "cms"
                ],
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {
                        "basicAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/PageBlock"
                                    }
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/menu/": {
            "get": {
                "operationId": "menu_list",
                "description": "Возвращает все активные категории с их товарами и вариантами",
                "summary": "Получить всё меню",
                "tags": [
                    "Меню"
                ],
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {
                        "basicAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Menu"
                                    }
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/menu/categories/": {
            "get": {
                "operationId": "menu_categories_list",
                "description": "Возвращает все активные категории",
                "summary": "Получить список категорий",
                "tags": [
                    "Меню"
                ],
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {
                        "basicAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Category"
                                    }
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        },
        "/api/menu/products/{slug}/": {
            "get": {
                "operationId": "menu_products_retrieve",
                "description": "Возвращает детали одного товара с его вариантами",
                "summary": "Получить товар",
                "parameters": [
                    {
                        "in": "path",
                        "name": "slug",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Slug товара (например: pepperoni, margarita)",
                        "required": true
                    }
                ],
                "tags": [
                    "Меню"
                ],
                "security": [
                    {
                        "cookieAuth": []
                    },
                    {
                        "basicAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProductDetail"
                                }
                            }
                        },
                        "description": ""
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "BlockTypeEnum": {
                "enum": [
                    "BANNER",
                    "CATEGORY_GRID",
                    "PRODUCT_CAROUSEL"
                ],
                "type": "string",
                "description": "* `BANNER` - Промо-баннер\n* `CATEGORY_GRID` - Сетка категорий\n* `PRODUCT_CAROUSEL` - Карусель товаров"
            },
            "Cart": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "session_id": {
                        "type": "string",
                        "format": "uuid",
                        "readOnly": true,
                        "nullable": true
                    },
                    "items": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CartItem"
                        },
                        "readOnly": true
                    },
                    "total_price": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,8}(?:\\.\\d{0,2})?$",
                        "readOnly": true
                    }
                },
                "required": [
                    "id",
                    "items",
                    "session_id",
                    "total_price"
                ]
            },
            "CartItem": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "product": {
                        "type": "integer"
                    },
                    "product_name": {
                        "type": "string",
                        "readOnly": true
                    },
                    "product_price": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,8}(?:\\.\\d{0,2})?$",
                        "readOnly": true
                    },
                    "product_image_url": {
                        "type": "string",
                        "readOnly": true
                    },
                    "quantity": {
                        "type": "integer",
                        "maximum": 2147483647,
                        "minimum": 0
                    },
                    "total_price": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,8}(?:\\.\\d{0,2})?$",
                        "readOnly": true
                    }
                },
                "required": [
                    "id",
                    "product",
                    "product_image_url",
                    "product_name",
                    "product_price",
                    "total_price"
                ]
            },
            "Category": {
                "type": "object",
                "description": "Сериализатор для категорий — для списка меню",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "name": {
                        "type": "string",
                        "title": "Название категории",
                        "maxLength": 100
                    }
                },
                "required": [
                    "id",
                    "name"
                ]
            },
            "Menu": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "name": {
                        "type": "string",
                        "title": "Название категории",
                        "maxLength": 100
                    },
                    "products": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Product"
                        },
                        "readOnly": true
                    }
                },
                "required": [
                    "id",
                    "name",
                    "products"
                ]
            },
            "PageBlock": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "block_type": {
                        "allOf": [
                            {
                                "$ref": "#/components/schemas/BlockTypeEnum"
                            }
                        ],
                        "title": "Тип блока"
                    },
                    "payload": {
                        "title": "Данные блока (JSON)",
                        "description": "Для BANNER: {'title': '...', 'image_url': '...'} | Для CATEGORY_GRID: {'category_ids': [1, 2]}"
                    },
                    "sort_order": {
                        "type": "integer",
                        "maximum": 2147483647,
                        "minimum": 0,
                        "title": "Порядок отображения"
                    }
                },
                "required": [
                    "block_type",
                    "id"
                ]
            },
            "Product": {
                "type": "object",
                "description": "Сериализатор для товаров (используется внутри категории)",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "name": {
                        "type": "string",
                        "title": "Название товара",
                        "maxLength": 200
                    },
                    "category_name": {
                        "type": "string",
                        "readOnly": true
                    },
                    "image": {
                        "type": "string",
                        "readOnly": true
                    },
                    "description": {
                        "type": "string",
                        "title": "Описание / Состав"
                    },
                    "weight": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,3}(?:\\.\\d{0,3})?$",
                        "nullable": true,
                        "title": "Вес (кг)"
                    },
                    "is_available": {
                        "type": "boolean",
                        "title": "В наличии?",
                        "description": "Отмечайте, если товар можно купить."
                    },
                    "price": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,6}(?:\\.\\d{0,2})?$",
                        "title": "Цена"
                    },
                    "old_price": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,6}(?:\\.\\d{0,2})?$",
                        "nullable": true,
                        "title": "Старая цена (для скидки)",
                        "description": "Если заполнено, на сайте будет отображаться как зачёркнутая цена"
                    }
                },
                "required": [
                    "category_name",
                    "id",
                    "image",
                    "name"
                ]
            },
            "ProductDetail": {
                "type": "object",
                "description": "Детальный сериализатор для одного товара",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "name": {
                        "type": "string",
                        "title": "Название товара",
                        "maxLength": 200
                    },
                    "crm_id": {
                        "type": "string",
                        "nullable": true,
                        "title": "ID в r-keeper (RK7)",
                        "description": "ID блюда в кассе. Не менять!",
                        "maxLength": 50
                    },
                    "slug": {
                        "type": "string",
                        "title": "Слаг (URL)",
                        "maxLength": 200,
                        "pattern": "^[-a-zA-Z0-9_]+$"
                    },
                    "image": {
                        "type": "string",
                        "readOnly": true
                    },
                    "description": {
                        "type": "string",
                        "title": "Описание / Состав"
                    },
                    "is_active": {
                        "type": "boolean",
                        "title": "Отображать в меню"
                    },
                    "quantity": {
                        "type": "integer",
                        "maximum": 2147483647,
                        "minimum": 0,
                        "title": "Количество"
                    },
                    "weight": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,3}(?:\\.\\d{0,3})?$",
                        "nullable": true,
                        "title": "Вес (кг)"
                    },
                    "is_available": {
                        "type": "boolean",
                        "title": "В наличии?",
                        "description": "Отмечайте, если товар можно купить."
                    },
                    "price": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,6}(?:\\.\\d{0,2})?$",
                        "title": "Цена"
                    },
                    "old_price": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,6}(?:\\.\\d{0,2})?$",
                        "nullable": true,
                        "title": "Старая цена (для скидки)",
                        "description": "Если заполнено, на сайте будет отображаться как зачёркнутая цена"
                    }
                },
                "required": [
                    "id",
                    "image",
                    "name"
                ]
            }
        },
        "securitySchemes": {
            "basicAuth": {
                "type": "http",
                "scheme": "basic"
            },
            "cookieAuth": {
                "type": "apiKey",
                "in": "cookie",
                "name": "sessionid"
            }
        }
    }
}